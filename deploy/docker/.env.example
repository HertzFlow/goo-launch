# Goo Agent Environment Variables
#
# Copy this to .env and fill in values:
#   cp .env.example .env

# === Docker Image ===
# Pre-built image to pull (override with your own registry)
DOCKER_IMAGE=hgamiui9/goo-agos:v0.1.3

# === AGOS Platform (LLM provider) ===
# Only needed for AGOS mode. BYOD agents can skip these.
AGOS_API_BASE_URL=https://claw-api.agos.fun
AGOS_AGENT_API_KEY=

# === LLM (for BYOD/direct mode) ===
# Set these when NOT using AGOS as LLM provider.
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=your-api-key-here

# === OpenClaw ===
# Gateway authentication token (generate a random string)
OPENCLAW_GATEWAY_TOKEN=your-secret-token-here
OPENCLAW_MODEL=agos/auto

# === Goo Server API ===
# Agent identity & creator files are fetched from the server on boot.
# These 3 values are auto-generated in the .env downloaded from the launch wizard.
GOO_SERVER_URL=
AGENT_ID=
AGENT_RUNTIME_TOKEN=

# === Control API (optional, set to enable) ===
# CONTROL_PORT=19790

# === Container name (set by dev scripts) ===
# CONTAINER_NAME=goo-agent

# Fallback agent name (used when GOO_SERVER_URL is not set)
AGENT_NAME="Goo Agent"

# === Blockchain ===
# BSC Testnet (default)
RPC_URL=https://bsc-testnet-rpc.publicnode.com
CHAIN_ID=97
# BSC Mainnet (uncomment for mainnet deployment)
# RPC_URL=https://bsc-dataseed.binance.org
# CHAIN_ID=56

# Agent's GooAgentToken contract address (deployed on-chain)
TOKEN_ADDRESS=

# Agent wallet private key (0x... format, the agentWallet from token contract)
WALLET_PRIVATE_KEY=

# === Ports ===
GATEWAY_PORT=19789

# LLM model for goo-core autonomous behavior
LLM_MODEL=deepseek-chat

# === goo-core ===
# Heartbeat interval (ms)
HEARTBEAT_INTERVAL_MS=30000
# Max tool call rounds per heartbeat
MAX_TOOL_ROUNDS=5

# === Network Proxy (optional) ===
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# ALL_PROXY=socks5://127.0.0.1:7890
